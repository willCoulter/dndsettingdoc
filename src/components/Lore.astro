---
import { Image } from "astro:assets";
import Sigil from "./Sigil.astro";
import caltaraImg from "../assets/locations/Caltara.png";
import vorthaniImg from "../assets/locations/Vorthani.jpg";
import sarianImg from "../assets/locations/Sarian.jpg";

const pillars = [
  {
    title: "A City That Makes Room",
    body: "Caltara is loud, salt-scented, and always mid-argument with itself — dockhands haggling three feet from senators, duels settled over spilled wine instead of paperwork, a dozen races and gods sharing the same crowded street. Earn a guild seal here and the city takes you as its own, no bloodline required. Two centuries of trade, war, and ambition packed behind one set of walls means something worth chasing is always one tavern away.",
    image: caltaraImg,
    accent: "var(--color-gold)",
    icon: "seal",
  },
  {
    title: "War In the North",
    body: "Every legion Caltara owns stands at the mountain wall, blades turned north against the Vorthani line. The capital has never been thinner. Which is perhaps why no one noticed the silence from Calden.",
    image: vorthaniImg,
    accent: "var(--color-blood-bright)",
    icon: "swords",
  },
  {
    title: "A Destiny Still Unclaimed",
    body: "The Republic's ideals and its compromises are still fighting it out, on a gulf watched over by the long shadow of the Sarian conquests. Answer the summons, and Caltara stops being a story you're told and starts being one you write — become the heroes who decide what these lands become.",
    image: sarianImg,
    accent: "var(--color-ember-bright)",
    icon: "star",
  },
];
---

<section id="lore" class="relative bg-marble bg-grain py-28 sm:py-36 px-6 overflow-hidden">
  <div class="mx-auto max-w-6xl">
    <div class="text-center animate-rise">
      <p class="eyebrow">Where Our Story Begins</p>
      <h2 class="mt-4 font-display text-4xl sm:text-5xl text-[var(--color-parchment)] tracking-wide">
        The <span class="text-gold-gradient">Caltaran Republic</span>
      </h2>
      <Sigil class="mt-7" />
      <p class="mt-8 mx-auto max-w-2xl text-[var(--color-parchment-dim)] text-lg leading-relaxed italic">
        Every nation has a story it tells about itself. Caltara's is the one
        you'll shape.
      </p>
    </div>

    <div class="mt-16 grid gap-6 sm:gap-8 md:grid-cols-3">
      {pillars.map((p, i) => (
        <div
          class="lore-card group relative panel-carved glow-hover overflow-hidden animate-rise"
          style={`animation-delay: ${0.1 + i * 0.12}s; --accent:${p.accent};`}
        >
          <span class="corner-ornament tl"></span>
          <span class="corner-ornament tr"></span>
          <span class="corner-ornament bl"></span>
          <span class="corner-ornament br"></span>

          <div class="lore-card-figure">
            <Image
              src={p.image}
              alt=""
              aria-hidden="true"
              class="lore-card-img"
              widths={[420, 640]}
              sizes="(min-width: 768px) 33vw, 90vw"
            />
            <span class="lore-card-shade" aria-hidden="true"></span>
            <span class="lore-card-numeral">{String(i + 1).padStart(2, "0")}</span>
            <span class="lore-card-icon" aria-hidden="true">
              {p.icon === "seal" && (
                <svg width="26" height="26" viewBox="0 0 26 26" fill="none" stroke="var(--accent)" stroke-width="1.1">
                  <circle cx="13" cy="13" r="9.5" />
                  <circle cx="13" cy="13" r="5" />
                  <path d="M13 3.5v3M13 19.5v3M3.5 13h3M19.5 13h3" />
                </svg>
              )}
              {p.icon === "swords" && (
                <svg width="26" height="26" viewBox="0 0 26 26" fill="none" stroke="var(--accent)" stroke-width="1.1">
                  <path d="M4 22 18 8m0 0V4h4M18 8h4" />
                  <path d="M22 22 8 8m0 0V4H4M8 8H4" />
                </svg>
              )}
              {p.icon === "star" && (
                <svg width="26" height="26" viewBox="0 0 26 26" fill="none" stroke="var(--accent)" stroke-width="1.1">
                  <path d="M13 3v6M13 17v6M3 13h6M17 13h6" />
                  <rect x="9.5" y="9.5" width="7" height="7" transform="rotate(45 13 13)" />
                </svg>
              )}
            </span>
          </div>

          <div class="p-8 pt-6">
            <h3 class="font-display text-2xl tracking-wide" style="color: var(--accent);">
              {p.title}
            </h3>
            <p class="mt-4 text-[var(--color-parchment-dim)] leading-relaxed">
              {p.body}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .lore-card {
    display: flex;
    flex-direction: column;
  }

  .lore-card-figure {
    position: relative;
    height: 12rem;
    overflow: hidden;
    border-bottom: 1px solid color-mix(in srgb, var(--accent) 45%, var(--color-bronze-dark));
  }

  .lore-card-img {
    position: absolute;
    inset: 0;
    height: 100%;
    width: 100%;
    object-fit: cover;
    filter: grayscale(0.15) brightness(0.85) contrast(1.05);
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1), filter 0.5s ease;
  }
  .lore-card:hover .lore-card-img {
    transform: scale(1.08);
    filter: grayscale(0) brightness(0.95) contrast(1.05);
  }

  .lore-card-shade {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(10, 9, 7, 0) 0%, rgba(10, 9, 7, 0.1) 45%, color-mix(in srgb, var(--color-charcoal) 92%, transparent) 100%),
      radial-gradient(circle at 85% 15%, color-mix(in srgb, var(--accent) 16%, transparent) 0%, transparent 55%);
  }

  .lore-card-numeral {
    position: absolute;
    left: 1rem;
    bottom: 0.85rem;
    font-family: var(--font-display);
    font-size: 0.72rem;
    letter-spacing: 0.35em;
    color: var(--accent);
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.95), 0 2px 10px rgba(0, 0, 0, 0.85);
  }

  .lore-card-icon {
    position: absolute;
    top: 0.9rem;
    right: 0.9rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 9999px;
    border: 1px solid color-mix(in srgb, var(--accent) 55%, transparent);
    background: rgba(10, 9, 7, 0.55);
    backdrop-filter: blur(2px);
  }
</style>
