---
import { Image } from "astro:assets";
import Sigil from "./Sigil.astro";
import caltara from "../assets/Caltara.png";
---

<section id="caltara-top" class="relative h-[86svh] min-h-[560px] w-full overflow-hidden bg-[var(--color-obsidian)]">
  <div class="absolute inset-0 will-change-transform animate-ken-burns">
    <Image
      src={caltara}
      alt="Caltara, capital of the Caltaran Republic"
      class="h-full w-full object-cover object-center"
      widths={[640, 1024, 1600, 2396]}
      sizes="100vw"
      priority
    />
  </div>

  <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-obsidian)] via-[var(--color-obsidian)]/40 to-transparent"></div>
  <div class="absolute inset-0 bg-gradient-to-r from-[var(--color-obsidian)]/50 via-transparent to-[var(--color-obsidian)]/30"></div>
  <div class="absolute inset-0 bg-grain"></div>
  <div class="pointer-events-none absolute inset-0 shadow-[inset_0_0_160px_60px_rgba(10,9,7,0.55)]"></div>

  <div class="embers" aria-hidden="true">
    {Array.from({ length: 10 }, (_, i) => (
      <span
        style={`--x:${(i * 9.3 + (i % 3) * 11) % 100}%; --sz:${2 + ((i * 37) % 3)}px; --dur:${12 + ((i * 13) % 8)}s; --delay:${-(i * 1.9)}s; --dx:${((i % 5) - 2) * 12}px; --o:${(0.3 + ((i * 17) % 40) / 100).toFixed(2)};`}
      ></span>
    ))}
  </div>

  <div class="relative z-10 flex h-full flex-col items-center justify-end px-6 pb-20 text-center sm:pb-24">
    <p class="eyebrow animate-rise text-[var(--color-gold-bright)]" style="animation-delay: 0.1s;">Capital of the Caltaran Republic</p>
    <h1 class="relative mt-5 font-display font-black uppercase leading-[0.95] text-6xl sm:text-7xl lg:text-8xl tracking-wide animate-rise" style="animation-delay: 0.2s;">
      <span class="absolute inset-0 blur-2xl opacity-40 text-gold-gradient" aria-hidden="true">Caltara</span>
      <span class="relative text-shimmer">Caltara</span>
    </h1>
    <div class="mt-6 animate-rise" style="animation-delay: 0.3s;">
      <Sigil />
    </div>
    <p class="mt-6 max-w-xl font-body text-lg text-[var(--color-parchment)]/90 italic animate-rise" style="animation-delay: 0.4s;">
      Where the Covenant of White Shores was signed two centuries ago, and
      where its cracks still show clearest.
    </p>
  </div>
</section>
