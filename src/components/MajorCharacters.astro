---
import { Image } from "astro:assets";
import Sigil from "./Sigil.astro";
import FigureCard from "./FigureCard.astro";
import caltaraCity from "../assets/CaltaraCity.jpg";
import lysanderImg from "../assets/npcs/lysander.jpg";
import caelindorImg from "../assets/npcs/caelindor.jpg";
import verathImg from "../assets/npcs/verath.jpg";
import octaviaImg from "../assets/npcs/Octavia.jpg";
import hadrosImg from "../assets/npcs/Hadros.jpg";
import matriarchImg from "../assets/npcs/matriarch.png";
import frogImg from "../assets/npcs/frog.jpg";
import alaundoImg from "../assets/npcs/Alaundo.jpg";

type Character = {
  name: string;
  role: string;
  hook: string;
  color: string;
  image?: ImageMetadata;
};

const primary: Character[] = [
  {
    name: "Lysander",
    role: "Senator, Open Senate",
    hook: "The senator who sent word to Calden — polished, well-liked, and willing to pay adventurers what the Senate won't.",
    color: "var(--color-gold)",
    image: lysanderImg,
  },
  {
    name: "Octavia",
    role: "The Closed Senate's Legal Mind",
    hook: "One of three seats, and the only one who bothers explaining her votes. That courtesy is not the same as an answer.",
    color: "var(--color-blood-bright)",
    image: octaviaImg,
  },
  {
    name: "General Caelindor",
    role: "Commander, Caelindor's Legion",
    hook: "Recalled from the northern wall three weeks ago. Hasn't answered. Half the capital already calls him a hero for it.",
    color: "var(--color-verdigris)",
    image: caelindorImg,
  },
  {
    name: "Hadros",
    role: "The Closed Senate's Public Face",
    hook: "Middle-aged for a dwarf, he's watched human politics cycle for longer than most humans have been alive. The Closed Senate's public face is considerably more calculating than it looks.",
    color: "var(--color-bronze)",
    image: hadrosImg,
  },
];

const more: Character[] = [
  {
    name: "Guildmistress Corvane",
    role: "The Central Districts' Guild Houses",
    hook: "She decides how long a guild application sits on a desk. She has never once explained why.",
    color: "var(--color-ember-bright)",
  },
  {
    name: "Alaundo",
    role: "Grand Oracle, Head of the Faith",
    hook: "One of the few voices the Republic's dozen priesthoods actually agree to listen to. Forty years spent interpreting gods who haven't spoken back in two centuries, and he insists that isn't as strange as it sounds.",
    color: "var(--color-gold)",
    image: alaundoImg,
  },
  {
    name: "Verath",
    role: "The Erinyes, Bound Hunter of the Old District",
    hook: "Once an angel. Now a hunter of oath-breakers under a pact two centuries old. The Republic calls the arrangement permitted.",
    color: "var(--color-blood-bright)",
    image: verathImg,
  },
  {
    name: "Guildmaster Ferro",
    role: "Head of the Vintners' Guild",
    hook: "A hag turned him into a talking frog eleven years ago, out of spite or as a lesson, depending who's asked. He still runs the guild, from a lily pond in his own courtyard, with a secretary fluent in croaks.",
    color: "var(--color-verdigris)",
    image: frogImg,
  },
];

const foreign: Character[] = [
  {
    name: "The Matriarch Eternal",
    role: "God-Chosen Ruler, the Sarian Theocracy",
    hook: "High elven, brilliant, and unhurried, with centuries to refine her methods and the patience to outlast any human-scale crisis. Rulers who thought they could wait her out have died. Their children have died. She remains.",
    color: "var(--color-gold)",
    image: matriarchImg,
  },
];
---

<section id="figures" class="relative w-full overflow-hidden bg-[var(--color-obsidian)] py-28 sm:py-36 px-6">
  <Image
    src={caltaraCity}
    alt=""
    aria-hidden="true"
    class="absolute inset-0 h-full w-full object-cover object-center"
    widths={[640, 1024, 1294]}
    sizes="100vw"
  />
  <div class="absolute inset-0 bg-[var(--color-obsidian)]/50"></div>
  <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-obsidian)] via-[var(--color-obsidian)]/35 to-[var(--color-obsidian)]/40"></div>
  <div class="absolute inset-0 bg-grain"></div>

  <div class="relative mx-auto max-w-6xl">
    <div class="text-center">
      <p class="eyebrow">Names Every Caltaran Knows</p>
      <h2 class="mt-4 font-display text-4xl sm:text-5xl text-[var(--color-parchment)] tracking-wide">
        Major <span class="text-gold-gradient">Characters</span>
      </h2>
      <Sigil class="mt-7" />
      <p class="mt-8 mx-auto max-w-2xl text-[var(--color-parchment-dim)] text-lg leading-relaxed">
        You haven't met these people. You've still heard of them &mdash;
        over a drink, in a rumor, or in a Senate address nobody quite
        believed.
      </p>
    </div>

    <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {primary.map((c, i) => (
        <FigureCard
          name={c.name}
          role={c.role}
          hook={c.hook}
          color={c.color}
          image={c.image}
          delay={0.06 + i * 0.08}
        />
      ))}
    </div>

    <details class="figures-more mt-5">
      <summary class="figures-more-trigger">
        <span class="font-display text-sm tracking-[0.2em] uppercase text-[var(--color-gold)]">
          View More Figures
        </span>
        <svg class="figures-chevron" width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
          <path d="M2 5l5 5 5-5" fill="none" stroke="var(--color-gold-dim)" stroke-width="1.4" />
        </svg>
      </summary>

      <div class="mt-5 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {more.map((c) => (
          <FigureCard name={c.name} role={c.role} hook={c.hook} color={c.color} image={c.image} />
        ))}
      </div>
    </details>

    <details class="figures-more mt-5">
      <summary class="figures-more-trigger">
        <span class="font-display text-sm tracking-[0.2em] uppercase text-[var(--color-gold)]">
          View Foreign Powers
        </span>
        <svg class="figures-chevron" width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
          <path d="M2 5l5 5 5-5" fill="none" stroke="var(--color-gold-dim)" stroke-width="1.4" />
        </svg>
      </summary>

      <div class="mt-5 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {foreign.map((c) => (
          <FigureCard name={c.name} role={c.role} hook={c.hook} color={c.color} image={c.image} />
        ))}
      </div>
    </details>
  </div>
</section>

<style>
  .figures-more summary {
    list-style: none;
  }
  .figures-more summary::-webkit-details-marker {
    display: none;
  }
  .figures-more-trigger {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    cursor: pointer;
    padding: 0.9rem;
    border: 1px solid var(--color-bronze-dark);
    background: rgba(10, 9, 7, 0.4);
    transition: border-color 0.3s ease;
  }
  .figures-more-trigger:hover {
    border-color: var(--color-gold-dim);
  }
  .figures-chevron {
    transition: transform 0.3s ease;
  }
  .figures-more[open] .figures-chevron {
    transform: rotate(180deg);
  }
  .figures-more[open] > div {
    animation: figures-rise 0.45s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  @keyframes figures-rise {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
