interface Face {
  key: string;
  name: string;
  epithet: string;
  image: ImageMetadata;
  accent: string;
  domain: string;
  body: string[];
}

interface God {
  name: string;
  epithet: string;
  image?: ImageMetadata;
  sigilOnly?: boolean;
  accent?: string;
  domain: string;
  body: string[];
  faces?: Face[];
}

interface Pantheon {
