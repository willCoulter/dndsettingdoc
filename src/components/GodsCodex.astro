const toRoman = (n: number) => {
  const table: [number, string][] = [
    [1000, "M"],
    [900, "CM"],
    [500, "D"],
    [400, "CD"],
    [100, "C"],
    [90, "XC"],
    [50, "L"],
    [40, "XL"],
    [10, "X"],
    [9, "IX"],
    [5, "V"],
    [4, "IV"],
    [1, "I"],
  ];
  let result = "";
  let num = n;
  for (const [value, symbol] of table) {
    while (num >= value) {
      result += symbol;
      num -= value;
    }
  }
  return result;
};

const sections = pantheons.map((p) => {
  const [headBefore, headAfter] = p.heading.split("{}");
  return {
    ...p,
    headBefore,
    headAfter,
    gods: p.gods.map((g, i) => ({
      ...g,
      id: g.name.toLowerCase().replace(/[^a-z]+/g, "-").replace(/^-|-$/g, ""),
      numeral: toRoman(i + 1),
      accent: g.accent ?? accents[i % accents.length],
      pantheonName: headBefore + p.goldWord + headAfter,
    })),
  };
});

const allGods = sections.flatMap((s) => s.gods);

const godCss = allGods
  .map(
    (g) => `
#codex:has(#g-${g.id}:checked) label[for="g-${g.id}"] {
  border-color: var(--color-gold);
  box-shadow: 0 18px 34px -16px rgba(0, 0, 0, 0.9), 0 0 0 1px var(--color-gold), 0 0 26px -8px color-mix(in srgb, ${g.accent} 60%, transparent);
  translate: 0 -6px;
}
#codex:has(#g-${g.id}:checked) label[for="g-${g.id}"]::after {
  opacity: 1;
  animation: shine-sweep-move 0.65s ease forwards;
}
#codex:has(#g-${g.id}:checked) .tome-entry--${g.id} {
  display: block;
}`,
  )
  .join("\n");
---

<section
  id="codex"
  class="relative bg-marble bg-grain py-28 sm:py-36 px-4 sm:px-6 overflow-x-clip"
>
  <div class="mx-auto max-w-7xl">
    <div class="text-center animate-rise">
      <p class="eyebrow">Faiths of the World</p>
      <h1
        class="mt-4 font-display text-4xl sm:text-6xl text-[var(--color-parchment)] tracking-wide"
      >
        The <span class="text-gold-gradient">Divine</span> Codex
      </h1>
      <Sigil class="mt-7" />
      <p
        class="mt-8 mx-auto max-w-2xl text-[var(--color-parchment-dim)] text-lg leading-relaxed"
      >
        The Living Gods hold the Republic, but they do not hold the world.
        State faiths, fey courts, warrior cults, and religions older than the
        First Age all claim their share of mortal devotion, and some claim a
        great deal more. Gathered here are the pantheons of Elderan as the
        codex-keepers of Caltara record them.
      </p>
      <p
        class="mt-3 font-display text-sm tracking-wide uppercase text-[var(--color-gold-dim)] animate-flicker"
      >
        Choose a card to open its entry in the codex
      </p>
    </div>

    <!-- default: nothing selected -->
    <input
      type="radio"
      name="codex-god"
      id="g-none"
      class="sr-only god-radio god-radio--none"
      checked
    />

    <div class="codex-layout mt-16 sm:mt-20">
      <div class="codex-sections">
        {
          sections.map((s) => (
            <div id={s.id} class="codex-section animate-rise">
              <div class="text-center">
                <p class="eyebrow">{s.eyebrow}</p>
                <h2 class="mt-3 font-display text-3xl sm:text-4xl text-[var(--color-parchment)] tracking-wide">
